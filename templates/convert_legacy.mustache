{{!
    @template format_menutab/convert_legacy

    Template for the legacy label conversion confirmation page.

    Context variables required for this template:
    * title - Page title
    * warning_title - Warning heading
    * warning_message - Warning message text
    * what_will_happen - Section heading
    * conversion_steps - Array of conversion steps
    * labels_to_convert_heading - Heading for labels list
    * h2_labels - Array of labels to convert
    * confirm_url - URL for confirmation
    * cancel_url - URL to cancel
    * confirm_button_text - Text for confirm button
    * cancel_button_text - Text for cancel button
    * sesskey - Session key
}}

<div class="container-fluid">
    <div class="alert alert-warning" role="alert">
        <h4 class="alert-heading">{{warning_title}}</h4>
        <p>{{warning_message}}</p>
    </div>

    <div class="alert alert-info" role="alert">
        <h5>{{what_will_happen}}</h5>
        <ul>
            {{#conversion_steps}}
            <li>{{{step}}}</li>
            {{/conversion_steps}}
        </ul>
    </div>

    {{#has_labels}}
    <div class="mb-3">
        <h5>{{labels_to_convert_heading}}</h5>
        <ul class="list-group mb-3">
            {{#h2_labels}}
            <li class="list-group-item">
                <strong>{{section_name}}</strong>: {{h2_text}}
            </li>
            {{/h2_labels}}
        </ul>
    </div>
    {{/has_labels}}

    <div class="mt-3">
        <form action="{{confirm_url}}" method="post">
            <input type="hidden" name="sesskey" value="{{sesskey}}">
            <input type="hidden" name="courseid" value="{{courseid}}">
            <input type="hidden" name="confirm" value="1">
            <button type="submit" class="btn btn-primary">{{confirm_button_text}}</button>
            <a href="{{cancel_url}}" class="btn btn-secondary ml-2">{{cancel_button_text}}</a>
        </form>
    </div>
</div>

